// Sauce Market — Schéma de données
// Prisma 5 · PostgreSQL 16

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================
//  USER
// =========================================================
enum Role {
  BUYER
  SELLER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

model User {
  id            String      @id @default(cuid())
  phone         String      @unique
  email         String?     @unique
  passwordHash  String?
  name          String
  avatarUrl     String?
  city          String?     @default("Dakar")
  role          Role        @default(BUYER)
  status        UserStatus  @default(ACTIVE)
  isVerified    Boolean     @default(false)
  ratingAvg     Float       @default(0)
  ratingCount   Int         @default(0)
  lang          String      @default("fr") // fr | wo
  fcmToken      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  subscriptions   Subscription[]
  products        Product[]       @relation("SellerProducts")
  ordersBought    Order[]         @relation("BuyerOrders")
  ordersSold      Order[]         @relation("SellerOrders")
  convAsBuyer     Conversation[]  @relation("BuyerConv")
  convAsSeller    Conversation[]  @relation("SellerConv")
  messages        Message[]
  reviewsWritten  Review[]        @relation("ReviewAuthor")
  reviewsReceived Review[]        @relation("ReviewTarget")
  reports         Report[]
  notifications   Notification[]

  @@index([city])
  @@index([role, status])
}

// =========================================================
//  SUBSCRIPTION (abonnement vendeur mensuel)
// =========================================================
enum SubStatus {
  PENDING
  ACTIVE
  CANCELED
  EXPIRED
  FAILED
}

enum PaymentProvider {
  WAVE
  ORANGE_MONEY
  FREE_MONEY
  PAYDUNYA
  CARD
}

model Subscription {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan       String          @default("MONTHLY_1000")
  amount     Int             // FCFA entiers
  currency   String          @default("XOF")
  status     SubStatus       @default(PENDING)
  provider   PaymentProvider
  providerRef String?        // ID transaction externe
  startsAt   DateTime?
  endsAt     DateTime?
  autoRenew  Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([userId, status])
  @@index([endsAt])
}

// =========================================================
//  CATEGORY (arbre)
// =========================================================
model Category {
  id         String     @id @default(cuid())
  name       String
  nameWolof  String?
  slug       String     @unique
  icon       String?
  parentId   String?
  parent     Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryTree")
  products   Product[]
  order      Int        @default(0)
}

// =========================================================
//  PRODUCT
// =========================================================
enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  SOLD
  HIDDEN
  REJECTED
}

model Product {
  id           String         @id @default(cuid())
  sellerId     String
  seller       User           @relation("SellerProducts", fields: [sellerId], references: [id], onDelete: Cascade)
  categoryId   String
  category     Category       @relation(fields: [categoryId], references: [id])
  title        String
  description  String
  price        Int            // FCFA
  currency     String         @default("XOF")
  stock        Int            @default(1)
  status       ProductStatus  @default(PENDING_REVIEW)
  city         String
  address      String?
  views        Int            @default(0)
  isPromoted   Boolean        @default(false)
  promoUntil   DateTime?
  rejectedReason String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  images        ProductImage[]
  orders        Order[]
  conversations Conversation[]
  reviews       Review[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([city, status])
  @@index([status, createdAt(sort: Desc)])
  @@index([isPromoted, promoUntil])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  publicId  String? // Cloudinary ID pour suppression
  order     Int     @default(0)

  @@index([productId])
}

// =========================================================
//  ORDER (commande + commission)
// =========================================================
enum OrderStatus {
  PENDING_PAYMENT
  PAID
  SHIPPED
  DELIVERED
  CANCELED
  DISPUTED
  REFUNDED
}

model Order {
  id          String          @id @default(cuid())
  buyerId     String
  buyer       User            @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId    String
  seller      User            @relation("SellerOrders", fields: [sellerId], references: [id])
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  quantity    Int             @default(1)
  amount      Int             // Total FCFA
  commission  Int             // FCFA
  currency    String          @default("XOF")
  status      OrderStatus     @default(PENDING_PAYMENT)
  provider    PaymentProvider?
  providerRef String?
  paidAt      DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  reviews Review[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

// =========================================================
//  CONVERSATION + MESSAGE
// =========================================================
model Conversation {
  id          String    @id @default(cuid())
  buyerId     String
  buyer       User      @relation("BuyerConv", fields: [buyerId], references: [id])
  sellerId    String
  seller      User      @relation("SellerConv", fields: [sellerId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  lastMessage String?
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
  messages    Message[]

  @@unique([buyerId, sellerId, productId])
  @@index([buyerId])
  @@index([sellerId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  body           String?
  imageUrl       String?
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// =========================================================
//  REVIEW
// =========================================================
model Review {
  id        String   @id @default(cuid())
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id])
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  authorId  String
  author    User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  targetId  String
  target    User     @relation("ReviewTarget", fields: [targetId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@unique([authorId, targetId, orderId])
  @@index([targetId])
}

// =========================================================
//  REPORT (signalement)
// =========================================================
enum ReportStatus {
  OPEN
  REVIEWING
  CLOSED
  ACTIONED
}

model Report {
  id          String       @id @default(cuid())
  reporterId  String
  reporter    User         @relation(fields: [reporterId], references: [id])
  targetType  String       // PRODUCT | USER | MESSAGE
  targetId    String
  reason      String
  details     String?
  status      ReportStatus @default(OPEN)
  createdAt   DateTime     @default(now())

  @@index([status, createdAt])
}

// =========================================================
//  NOTIFICATION (in-app)
// =========================================================
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  payload   Json
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, readAt])
}

// =========================================================
//  OTP (codes SMS temporaires)
// =========================================================
model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([phone, expiresAt])
}

// =========================================================
//  APP CONFIG (tunable by admin)
// =========================================================
model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
