# --- App ---
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
WEB_URL=http://localhost:5173

# --- Database ---
DATABASE_URL="postgresql://user:pass@localhost:5432/sauce_market?schema=public"
REDIS_URL="redis://localhost:6379"

# --- Auth ---
JWT_SECRET=change-me-in-prod-use-openssl-rand-hex-64
JWT_EXPIRES_IN=7d
REFRESH_EXPIRES_IN=30d

# --- OTP / SMS (Orange Sonatel or Twilio) ---
SMS_PROVIDER=orange
ORANGE_SMS_CLIENT_ID=xxx
ORANGE_SMS_CLIENT_SECRET=xxx
ORANGE_SMS_SENDER=SauceMkt

# --- Cloudinary (images) ---
CLOUDINARY_CLOUD_NAME=xxx
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx

# --- Payment (PayDunya aggregator + Wave direct) ---
PAYDUNYA_MASTER_KEY=xxx
PAYDUNYA_PRIVATE_KEY=xxx
PAYDUNYA_PUBLIC_KEY=xxx
PAYDUNYA_TOKEN=xxx
PAYDUNYA_MODE=test

WAVE_API_KEY=xxx
WAVE_WEBHOOK_SECRET=xxx

# --- Business rules ---
SUBSCRIPTION_MONTHLY_FCFA=1000
COMMISSION_RATE=0.05
PROMO_7D_FCFA=500

# --- Firebase Cloud Messaging ---
FCM_SERVER_KEY=xxx
